{
  "schemaVersion": 1,
  "evidenceTypes": {
    "objective": {
      "required": ["correct"],
      "reviewableDefault": true
    },
    "rubric": {
      "required": ["performance", "confidence"],
      "performanceRange": [0, 1],
      "reviewableDefault": false
    },
    "retrieval": {
      "required": ["rating"],
      "ratings": {
        "again": 0,
        "hard": 0.5,
        "good": 1
      },
      "reviewableDefault": true
    }
  },
